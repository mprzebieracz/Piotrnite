package frontend.concreteviews.basicviews;

import com.badlogic.gdx.Game;
import com.badlogic.gdx.Gdx;
import com.badlogic.gdx.ScreenAdapter;
import com.badlogic.gdx.scenes.scene2d.Stage;
import com.badlogic.gdx.scenes.scene2d.ui.Table;
import com.badlogic.gdx.utils.ScreenUtils;
import viewmodel.AbstractView;
import viewmodel.AbstractViewManager;

public class viewTemplate extends ScreenAdapter implements AbstractView {
    private final Game game;
    private final AbstractViewManager viewManager;

    private Stage stage;


    public viewTemplate(final Game game, final AbstractViewManager viewManager) {
        this.game = game;
        this.viewManager = viewManager;
    }

    @Override
    public void display() {
        game.setScreen(this);
    }


    @Override
    public void render(final float delta) {
        ScreenUtils.clear(0, 0, 0, 1, true);
        stage.act(delta);
        stage.draw();
    }

    @Override
    public void resize(final int width, final int height) {
        stage.getViewport().update(width, height, false);
    }

    @Override
    public void show() {
        //TODO hardcoded: remove hardcoded strings, use config instead
        stage = new Stage();
        Gdx.input.setInputProcessor(stage);

        //add stuff

        final Table table = viewManager.getTextureManager().getTable();
        //add that stuff to the table

        stage.addActor(table);
    }

    @Override
    public void dispose() {
        stage.dispose();
    }
}
